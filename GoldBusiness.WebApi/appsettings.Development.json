{
  "ConnectionStrings": {
    "DefaultConnection": "USAR-USER-SECRETS-PARA-CREDENCIALES"
  },
  "Jwt": {
    "Issuer": "GoldBusinessAPI",
    "Key": "USAR-USER-SECRETS-PARA-CREDENCIALES",
    "AccessTokenExpirationMinutes": 120,
    "RefreshTokenExpirationDays": 7
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information",
      "GoldBusiness": "Information"
    }
  },
  "AllowedHosts": "*",
  "ApiVersion": {
    "Major": 2,
    "Minor": 0,
    "Name": "v2.0"
  },
  "Cors": {
    "Development": {
      "AllowedOrigins": [
        "http://localhost:5173",
        "http://localhost:3000",
        "http://localhost:4200",
        "http://localhost:8080",
        "http://localhost:5000",
        "http://127.0.0.1:5173",
        "http://127.0.0.1:3000"
      ]
    }
  },
  "RateLimiting": {
    "Auth": {
      "PermitLimit": 50,
      "WindowMinutes": 1
    },
    "Api": {
      "PermitLimit": 500,
      "WindowMinutes": 1
    }
  },
  "Security": {
    "EnableSecurityHeaders": false,
    "EnableSecurityLogging": true,
    "EnableRateLimiting": false
  }
}
