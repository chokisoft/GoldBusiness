# Editor configuration, see https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.ts]
indent_style = space
indent_size = 2
quote_type = single
ij_typescript_use_double_quotes = false

[*.json]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.html]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.css]
indent_style = space
indent_size = 2

[*.scss]
indent_style = space
indent_size = 2

[*.md]
max_line_length = off
trim_trailing_whitespace = false

[*.sh]
end_of_line = lf
trim_trailing_whitespace = false
